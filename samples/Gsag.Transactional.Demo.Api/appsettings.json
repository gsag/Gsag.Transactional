{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "Observability": {
    "EnableTracing": false,
    "EnableMetrics": false,
    "Traces": {
      "Protocol": "Grpc",
      "Endpoint": "http://localhost:4317"
    },
    "Metrics": {
      "Protocol": "Grpc",
      "Endpoint": "http://localhost:4317"
    }
  },
  "AllowedHosts": "*"
}
