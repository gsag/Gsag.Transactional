{
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft.AspNetCore": "Warning",
        "Microsoft.EntityFrameworkCore": "Warning"
      }
    },
    "WriteTo": [
      { "Name": "Console" }
    ]
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "Observability": {
    "EnableTracing": false,
    "EnableMetrics": false,
    "EnableLogs": false,
    "Traces": {
      "Protocol": "Grpc",
      "Endpoint": "http://localhost:4317"
    },
    "Metrics": {
      "Protocol": "Grpc",
      "Endpoint": "http://localhost:4317"
    },
    "Logs": {
      "Protocol": "Grpc",
      "Endpoint": "http://localhost:4317"
    }
  },
  "AllowedHosts": "*"
}
