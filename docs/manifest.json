      },
      "version": "",
      "Uid": null,
      "IsMRef": true,
      "Title": "Gsag.Transactional.Core.Observability.TransactionInfo",
      "Summary": "<p sourcefile=\"api/Gsag.Transactional.Core.Observability.TransactionInfo.yml\" sourcestartlinenumber=\"1\">Stable public snapshot of a transaction's configuration, passed to\n<xref href=\"Gsag.Transactional.Core.Observability.ITransactionObserver\" data-throw-if-not-resolved=\"false\"></xref> at every lifecycle event.\nDecouples observer implementations from <xref href=\"System.Reflection.MethodInfo\" data-throw-if-not-resolved=\"false\"></xref>\nand from the proxy's internal wiring.</p>\n"
    },
